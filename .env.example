# code-smart environment variables
#
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env

# Path to the SQLite database file (default: ./data/code-smart.db)
# Only used at build time by the data pipeline scripts.
DB_PATH=./data/code-smart.db

# Environment mode: "development" | "production"
# Controls build-time behavior — "production" enforces stricter validation
# on artifact files (providers.json, plans.json, etc.) during next build.
NODE_ENV=development
