{
  "name": "code-smart",
  "version": "1.0.11",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm generate:rankings && pnpm generate:static-api && next build",
    "start": "next start",
    "lint": "next lint",
    "validate": "npx tsx scripts/validate-data.ts",
    "stale-check": "npx tsx scripts/stale-check.ts",
    "fetch": "npx tsx scripts/fetch-provider.ts",
"scrape:providers": "npx tsx scripts/scrape-providers.ts",
    "normalize:usage": "npx tsx scripts/normalize-usage.ts",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx src/db/index.ts --migrate",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:seed-aa": "npx tsx scripts/seed-aa-scores.ts",
    "generate:value-estimates": "npx tsx scripts/generate-model-value-estimates.ts",
    "generate:rankings": "npx tsx scripts/generate-rankings.ts",
    "generate:static-api": "npx tsx scripts/generate-static-api.ts",
    "pipeline:daily": "npx tsx scripts/pipeline-daily.ts",
    "pipeline:status": "npx tsx scripts/pipeline-daily.ts --status-only",
    "db:reset": "rm -f data/code-smart.db && npm run db:migrate && npm run db:seed",
    "db:pull-artifact": "gh run download --name code-smart-db --dir data/ || true",
    "db:push-artifact": "gh run upload --name code-smart-db data/code-smart.db || true"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.511.0",
    "next": "15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^3.2.3",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "playwright": "^1.60.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.2.3"
  }
}
